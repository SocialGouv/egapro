    fetch_issue --> check_analyse
    check_analyse --> analyse_router
    analyse_router -->|"expr: outputs.check_analyse.has_analyse == true"| detect_mode
    analyse_router --> propose_analyse
    propose_analyse --> fail
    detect_mode -->|"expr: outputs.fetch_issue.issueType == 'Feature'"| epic_guard
    detect_mode --> task_setup
    epic_guard --> epic_plan
    epic_plan --> epic_dispatch
    epic_dispatch --> ticket_setup
    ticket_setup --> code_dev_ticket
    code_dev_ticket -->|"validated"| merge_into_epic
    code_dev_ticket --> fail
    merge_into_epic --> epic_collect
    epic_collect --> epic_collect_route
    epic_collect_route -->|"expr: outputs.epic_collect.all_merged == true"| e2e_dev
    epic_collect_route --> epic_incomplete
    epic_incomplete --> fail
    task_setup --> code_dev
    code_dev --> code_dev_route
    code_dev_route -->|"expr: outputs.code_dev.status == 'source_ready'"| tu_dev
    code_dev_route -->|"expr: outputs.code_dev.status == 'needs_opus_escalation'"| escalate_opus
    code_dev_route -->|"expr: outputs.code_dev.status == 'refacto'"| refacto_done
    code_dev_route -->|"expr: outputs.code_dev.status == 'rate_limited'"| rate_limited_stop
    code_dev_route --> code_failed
    tu_dev --> tu_route
    tu_route -->|"expr: outputs.tu_dev.status == 'pass'"| gates_fanout
    tu_route -->|"expr: outputs.tu_dev.status == 'regression' / loop:tu_rework(3)"| code_dev
    tu_route --> code_failed
    gates_fanout --> validator
    gates_fanout --> structural_auditor
    gates_fanout --> rgaa_auditor
    gates_fanout --> security_auditor
    validator --> gates_consolidate
    structural_auditor --> gates_consolidate
    rgaa_auditor --> gates_consolidate
    security_auditor --> gates_consolidate
    gates_consolidate --> gates_route
    gates_route -->|"expr: outputs.gates_consolidate.passed == true"| functional_validator
    gates_route -->|"expr: outputs.gates_consolidate.route == 'test' / loop:gates_test_rework(3)"| tu_dev
    gates_route -->|"expr: outputs.gates_consolidate.route == 'source' / loop:gates_src_rework(3)"| code_dev
    gates_route --> refacto_done
    functional_validator --> func_route
    func_route -->|"expr: outputs.functional_validator.status == 'PASS'"| ci_wait
    func_route -->|"expr: outputs.functional_validator.status == 'RETRY' / loop:func_rework(2)"| code_dev
    func_route --> refacto_done
    ci_wait --> sonar_wait
    sonar_wait --> bot_review
    bot_review --> checks_route
    checks_route -->|"expr: outputs.bot_review.status == 'green'"| finalize_pr
    checks_route -->|"expr: outputs.bot_review.status == 'red' / loop:checks_rework(3)"| code_dev
    checks_route --> refacto_done
    finalize_pr --> e2e_dev
    e2e_dev --> e2e_route
    e2e_route -->|"expr: outputs.e2e_dev.status == 'validated' && outputs.fetch_issue.issueType == 'Feature'"| doc_writer
    e2e_route -->|"expr: outputs.e2e_dev.status == 'validated'"| task_handoff
    e2e_route -->|"expr: outputs.e2e_dev.status == 'regression' / loop:e2e_rework(3)"| architect_rework
    e2e_route --> e2e_stop
    architect_rework --> rework_route
    rework_route -->|"expr: outputs.architect_rework.status == 'tickets_created' / loop:epic_rework(3)"| epic_plan
    rework_route -->|"expr: outputs.architect_rework.status == 'needs_user'"| rework_human
    rework_route --> rework_stop
    rework_human -->|"approved / loop:rework_loop(5)"| architect_rework
    rework_human --> fail
    doc_writer --> open_final_pr
    open_final_pr --> accept_gate
    accept_gate --> accept_route
    accept_route -->|"expr: outputs.accept_gate.approved == true"| done
    accept_route --> reset_e2e_gate
    reset_e2e_gate --> architect_rework
    task_handoff --> done
    escalate_opus -->|"loop:opus_rework(3)"| code_dev
    refacto_done --> fail
    rate_limited_stop --> fail
    code_failed --> fail
    e2e_stop --> fail
    rework_stop --> fail

