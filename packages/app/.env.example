AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000/api/auth"
DATABASE_URL="postgresql://postgres:postgres@localhost:5438/egapro"
# Dedicated PG for the notifications queue — isolated from the main DB so a
# crash of the main infra does not lose pending notification jobs.
NOTIFICATIONS_DATABASE_URL="postgresql://postgres:postgres@localhost:5439/egapro_notifications"
EGAPRO_PROCONNECT_CLIENT_ID=""
EGAPRO_PROCONNECT_CLIENT_SECRET=""
EGAPRO_PROCONNECT_ISSUER=""
EGAPRO_WEEZ_API_URL=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Local Matomo (docker compose) — see scripts/matomo-local/README.md.
# Points at the local stack on :8080, site 1 (provisioned by `matomo-init`).
NEXT_PUBLIC_MATOMO_URL="http://localhost:8080"
NEXT_PUBLIC_MATOMO_SITE_ID="1"
# Server-side Matomo Reporting API for the admin stats widgets (issue #3646).
# Optional: the admin charts degrade to "no data" when MATOMO_API_TOKEN is unset.
# The token is generated by `matomo-init` into scripts/matomo-local/.secrets/token
# — copy it here. MATOMO_API_URL falls back to NEXT_PUBLIC_MATOMO_URL when empty.
MATOMO_API_TOKEN=""
MATOMO_API_URL=""
EGAPRO_GIP_MDS_API_URL="http://localhost:3000/api/gip-mds/mock"
EGAPRO_SUIT_API_URL=""
EGAPRO_MOCK_SUIT_SANCTION="true"
# Shared secret injected by the APISIX gateway (X-Gateway-Forwarded header)
# and verified by src/middleware.ts on /api/v1/* to prevent in-cluster bypass.
EGAPRO_GATEWAY_SHARED_SECRET="dev-gateway-shared-secret-minimum-32-chars"
NEXT_PUBLIC_EGAPRO_ENV="dev"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_NAME="egapro-dev-app"
CLAMAV_HOST="localhost"
CLAMAV_PORT="3310"
ADMIN_EMAILS="test@fia1.fr"
MAIL_ENABLED="true"
SMTP_HOST="localhost"
SMTP_PORT="1025"
MAIL_FROM="no-reply@egapro.local"
# Valkey cache — optional, app works without it (in-memory fallback)
VALKEY_URL="redis://localhost:6379"
