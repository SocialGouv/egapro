MAIL_ENABLED="true"
SMTP_HOST="localhost"
SMTP_PORT="1025"
MAIL_FROM="no-reply@egapro.local"
# Valkey cache — optional, app works without it (in-memory fallback)
VALKEY_URL="redis://localhost:6379"
