{
	"name": "app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node scripts/copy-dsfr.mjs && node scripts/copy-swagger-ui.mjs && next build",
		"prebuild": "pnpm --filter notifications build",
		"pretypecheck": "pnpm --filter notifications build",
		"pretest": "pnpm --filter notifications build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint --write .",
		"lint:check": "biome lint .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"dev": "node scripts/copy-dsfr.mjs && node scripts/copy-swagger-ui.mjs && next dev --turbo",
		"predev": "pnpm --filter notifications build",
		"preview": "next build && next start",
		"start": "next start",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"pretest:coverage": "pnpm --filter notifications build",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"pretest:integration": "pnpm --filter notifications build",
		"test:e2e": "playwright test",
		"pretest:e2e": "pnpm --filter notifications build",
		"test:e2e:ui": "playwright test --ui",
		"test:rgaa": "playwright test --config playwright.rgaa.config.ts",
		"test:lighthouse": "lhci collect --url=${LIGHTHOUSE_URL:-http://localhost:3000} && lhci upload && lhci assert",
		"typecheck": "tsc --noEmit",
		"generate:fetch-companies": "tsx scripts/fetch-companies.ts",
		"generate:mock-gip": "tsx scripts/generate-mock-gip-data.ts",
		"mock:refresh": "tsx scripts/fetch-companies.ts --per-bucket=40 && tsx scripts/generate-mock-gip-data.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1029.0",
		"@gouvfr/dsfr": "^1.14.4",
		"@hookform/resolvers": "^5.2.2",
		"@react-pdf/renderer": "^4.4.1",
		"@sentry/nextjs": "^10.48.0",
		"@socialgouv/matomo-next": "^1.13.1",
		"@t3-oss/env-nextjs": "^0.13.11",
		"@tanstack/react-query": "^5.99.0",
		"@trpc/client": "^11.16.0",
		"@trpc/react-query": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"drizzle-orm": "^0.45.2",
		"exceljs": "^4.4.0",
		"next": "^16.2.3",
		"next-auth": "4.24.13",
		"notifications": "workspace:*",
		"postgres": "^3.4.9",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.72.1",
		"recharts": "^3.8.1",
		"redis": "^5.11.0",
		"server-only": "^0.0.1",
		"superjson": "^2.2.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@biomejs/biome": "^2.4.11",
		"@lhci/cli": "^0.15.1",
		"@playwright/test": "^1.59.1",
		"@testcontainers/postgresql": "^11.14.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"@vitest/coverage-v8": "^4.1.4",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^29.0.2",
		"sass": "^1.99.0",
		"swagger-ui-dist": "^5.32.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.4"
	},
	"packageManager": "pnpm@10.8.1"
}
